{
  "name": "hello-world-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build && youtrack-app validate dist",
    "pack": "rm -rf hello-world-app.zip && cd dist && zip -r ../hello-world-app.zip .",
    "upload": "youtrack-app upload dist"
  },
  "dependencies": {
    "@jetbrains/ring-ui-built": "^7.0.79",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@jetbrains/youtrack-apps-tools": "^0.0.2",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-static-copy": "^3.1.4"
  }
}
