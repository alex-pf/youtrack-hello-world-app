{
  "$schema": "https://json.schemastore.org/youtrack-app.json",
  "name": "hello-world-app",
  "title": "Hello World App",
  "description": "A dashboard widget that displays a list of YouTrack issues matching a search query",
  "version": "1.5.2",
  "icon": "hello-world-logo.svg",
  "iconDark": "hello-world-logo-dark.svg",
  "url": "https://github.com/alex-pf/youtrack-hello-world-app",
  "minYouTrackVersion": "2024.3.0",
  "vendor": {
    "name": "alex-pf",
    "url": "https://github.com/alex-pf",
    "email": "prizrakfantezi@gmail.com"
  },
  "widgets": [
    {
      "key": "hello-world-widget",
      "name": "Hello World Issues",
      "description": "Displays a list of YouTrack issues matching a search query",
      "iconPath": "hello-world/widget-icon.svg",
      "indexPath": "hello-world/index.html",
      "extensionPoint": "DASHBOARD_WIDGET",
      "settingsSchemaPath": "hello-world/widget-settings.json",
      "permissions": ["READ_ISSUE"]
    }
  ]
}
